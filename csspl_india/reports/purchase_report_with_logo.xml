<odoo>

    <!-- Modern wkhtmltopdf-safe Purchase Order: WITH LOGO - CUSTOM CONTROLLED LAYOUT -->
    <template id="report_purchaseorder_document1">

        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>

        <style type="text/css">
            /* =====================================================
               WKHTMLTOPDF SAFE CSS
               No Google Fonts, no flex, no grid
               ===================================================== */

            * {
                box-sizing: border-box;
            }

            body {
                font-family: Arial, Helvetica, sans-serif;
                color: #172033;
                font-size: 11px;
                line-height: 1.35;
                margin: 0 !important;
                padding: 0 !important;
            }

            .page {
                margin: 0 !important;
                padding: 0 !important;
            }

            /* =====================================================
               MAIN WIDTH / SIDE MARGIN CONTROL

               width 94% = normal side margin
               width 92% = more left/right margin
               width 96% = less left/right margin
               ===================================================== */

.po-outer {
    width: 94% !important;
    margin-left: auto !important;
    margin-right: auto !important;
    margin-top: 0 !important;
    padding: 0 !important;
}

            /* =====================================================
               LOGO + COMPANY HEADER CONTROL
               ===================================================== */

            .po-company-head {
                width: 100% !important;
                border-collapse: collapse !important;
                margin: 0 0 12px 0 !important;
                padding: 0 !important;
                page-break-inside: avoid;
            }

            .po-company-logo-cell {
                width: 260px;
                vertical-align: top;
                text-align: left;
                padding: 0 12px 4px 0 !important;
            }

            .po-company-info-cell {
                vertical-align: top;
                text-align: left;
                padding: 8px 0 4px 0 !important;
                color: #172033;
                font-size: 11px;
                line-height: 1.35;
            }

            .po-company-logo {
                max-width: 240px !important;
                max-height: 80px !important;
                display: block;
                margin: 0 !important;
                padding: 0 !important;
            }

            .po-company-name {
                font-size: 13px;
                font-weight: 700;
                color: #172033;
            }

            /* =====================================================
               PURCHASE ORDER TITLE BLOCK
               ===================================================== */

            .po-title-table {
                width: 100% !important;
                border-collapse: collapse !important;
                margin: 0 0 12px 0 !important;
                page-break-inside: avoid;
                border: 1px solid #10233f;
                background: #ffffff;
            }

            .po-title-table td {
                border: 1px solid #10233f;
            }

            .po-title-left {
                width: 64%;
                padding: 10px 12px !important;
                vertical-align: middle;
            }

            .po-title-right {
                width: 36%;
                padding: 10px 12px !important;
                text-align: right;
                vertical-align: middle;
            }

            .po-title {
                margin: 0;
                padding: 0;
                font-size: 20px;
                line-height: 1.15;
                letter-spacing: .6px;
                color: #10233f;
                font-weight: 700;
                text-transform: uppercase;
            }

            .po-subtitle {
                margin-top: 3px;
                font-size: 10px;
                color: #5b677a;
            }

.po-badge {
    display: inline-block;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    color: #10233f;
    padding: 5px 10px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .4px;
    background: transparent !important;
}
            /* =====================================================
               ADDRESS CARD
               ===================================================== */

            .po-card {
                width: 100% !important;
                border-collapse: collapse !important;
                border: 1px solid #d7dee8;
                background: #ffffff;
                margin: 0 0 8px 0 !important;
                page-break-inside: avoid;
            }

            /* =====================================================
   HTML NOTE / TERMS FIX
   Force Odoo HTML field content to follow report style
   ===================================================== */

.po-note-box {
    border: 1px solid #d7dee8 !important;
    padding: 10px 12px !important;
    margin-top: 8px !important;
    background: #ffffff !important;
    page-break-inside: auto !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    white-space: normal !important;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 10px !important;
    line-height: 1.35 !important;
    color: #172033 !important;
}

.po-note-box *,
.po-note-content,
.po-note-content * {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 10px !important;
    line-height: 1.35 !important;
    color: #172033 !important;
    box-sizing: border-box !important;
    max-width: 100% !important;
}

.po-note-content {
    width: 100% !important;
    display: block !important;
    overflow: visible !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    white-space: normal !important;
}

.po-note-content table {
    width: 100% !important;
    max-width: 100% !important;
    border-collapse: collapse !important;
    table-layout: fixed !important;
    margin: 6px 0 !important;
    border: 1px solid #d7dee8 !important;
}

.po-note-content table td,
.po-note-content table th {
    border: 1px solid #d7dee8 !important;
    padding: 7px 9px !important;
    vertical-align: top !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    white-space: normal !important;
}

.po-note-content p,
.po-note-content div {
    margin: 0 0 4px 0 !important;
    padding: 0 !important;
}

.po-note-content strong,
.po-note-content b {
    font-weight: 700 !important;
}

            .po-card td,
            .po-card th {
                border: 1px solid #d7dee8 !important;
                padding: 13px 15px !important;
                vertical-align: top !important;
            }

            .po-section-head {
                font-size: 10px;
                text-transform: uppercase;
                color: #10233f;
                font-weight: 700;
                letter-spacing: .35px;
                margin-bottom: 6px;
            }

            .po-address {
                word-wrap: break-word;
                overflow-wrap: break-word;
                white-space: normal;
                font-size: 11px;
                line-height: 1.35;
                color: #172033;
            }

            /* =====================================================
               META INFO TABLE
               ===================================================== */

            .po-meta-table {
                width: 100% !important;
                border-collapse: collapse !important;
                margin: 0 0 8px 0 !important;
                page-break-inside: avoid;
            }

            .po-meta-table td {
                border: 1px solid #d7dee8 !important;
                padding: 12px 15px !important;
                vertical-align: top !important;
                background: #fbfcfe !important;
            }

            .po-label {
                color: #5b677a;
                font-size: 9px;
                text-transform: uppercase;
                letter-spacing: .25px;
                font-weight: 700;
            }

            .po-value {
                display: block;
                color: #172033;
                font-size: 11px;
                font-weight: 600;
                margin-top: 2px;
                word-wrap: break-word;
                overflow-wrap: break-word;
            }

            /* =====================================================
               ORDER LINE TABLE
               ===================================================== */

            .po-lines {
                width: 100% !important;
                border-collapse: collapse !important;
                table-layout: fixed !important;
                margin: 0 !important;
                font-size: 10px;
            }

            .po-lines thead {
                display: table-header-group;
            }

            .po-lines th {
                background: #10233f;
                color: #ffffff;
                border: 1px solid #10233f;
                padding: 11px 10px !important;
                font-size: 9px;
                text-transform: uppercase;
                letter-spacing: .25px;
                vertical-align: middle;
            }

            .po-lines td {
                border: 1px solid #d7dee8;
                padding: 9px 10px !important;
                vertical-align: top;
                color: #172033;
                word-wrap: break-word;
                overflow-wrap: break-word;
            }

            .po-lines tbody tr:nth-child(even) td {
                background: #fbfcfe;
            }

            .po-col-sr {
                width: 3%;
                text-align: center;
            }

            .po-col-desc {
                width: 36%;
            }

            .po-col-hsn {
                width: 11%;
                text-align: center;
            }

            .po-col-tax {
                width: 14%;
            }

            .po-col-qty {
                width: 12%;
                text-align: right;
            }

            .po-col-rate {
                width: 10%;
                text-align: right;
            }

            .po-col-amt {
                width: 14%;
                text-align: right;
            }

            .po-product-name {
                font-weight: 700;
                color: #10233f;
            }

            .po-muted {
                color: #647085;
            }

            .po-line-desc {
                word-wrap: break-word;
                overflow-wrap: break-word;
                white-space: normal;
            }

            .po-section-row td {
                background: #edf3fb !important;
                color: #10233f;
                font-weight: 700;
                text-transform: uppercase;
            }

            .po-note-row td {
                background: #fffaf0 !important;
                color: #4b5563;
                font-style: italic;
            }

            .po-subtotal-row td {
                background: #f5f8fc !important;
                font-weight: 700;
                text-align: right;
            }

            .po-total-row td {
                background: #fbfcfe !important;
                color: #172033 !important;
                font-weight: 700 !important;
                border: 1px solid #d7dee8 !important;
                padding: 9px 12px !important;
                vertical-align: middle !important;
            }

            .po-total-row td:last-child {
                text-align: right !important;
                padding-right: 16px !important;
            }

            .po-right {
                text-align: right;
            }

            .po-center {
                text-align: center;
            }

            /* =====================================================
               TAX SUMMARY
               ===================================================== */

            .po-summary-wrap {
                width: 100% !important;
                border-collapse: collapse !important;
                margin: 8px 0 0 0 !important;
                page-break-inside: avoid;
            }

            .po-summary-left {
                width: 58%;
                vertical-align: top;
                padding-right: 8px;
            }

            .po-summary-right {
                width: 42%;
                vertical-align: top;
            }

            .po-tax-table {
                width: 100% !important;
                border-collapse: collapse !important;
                border: 1px solid #d7dee8 !important;
            }

            .po-tax-table td,
            .po-tax-table th {
                padding: 8px 12px !important;
                border: 1px solid #d7dee8 !important;
                color: #172033 !important;
                background: #ffffff !important;
                font-size: 10px !important;
                vertical-align: middle !important;
            }

            .po-tax-table td:first-child,
            .po-tax-table th:first-child {
                text-align: left !important;
            }

            .po-tax-table td:last-child,
            .po-tax-table th:last-child {
                text-align: right !important;
                padding-right: 16px !important;
            }

            /* =====================================================
               AMOUNT WORDS / NOTE / SIGNATURE
               ===================================================== */

            .po-amount-words {
                border: 1px solid #d7dee8;
                padding: 10px 12px;
                margin-top: 8px;
                background: #fbfcfe;
                page-break-inside: avoid;
                word-wrap: break-word;
                overflow-wrap: break-word;
            }

            .po-note-box {
                border: 1px solid #d7dee8;
                padding: 10px 12px;
                margin-top: 8px;
                min-height: 28px;
                page-break-inside: auto;
                word-wrap: break-word;
                overflow-wrap: break-word;
                white-space: normal;
            }

            .po-sign-table {
                width: 100% !important;
                border-collapse: collapse !important;
                margin-top: 8px;
                page-break-inside: avoid;
            }

            .po-sign-table td {
                border: 1px solid #d7dee8 !important;
                padding: 14px 15px !important;
                vertical-align: top !important;
            }

            .po-sign-space {
                height: 58px;
            }

            .po-digital-note {
                text-align: center;
                font-size: 9px;
                color: #647085;
            }

            .header_text {
                font-size: 11px;
            }

            .content_text {
                font-size: 10px;
            }
        </style>

        <div class="page">

            <div class="po-outer">

                <!-- COMPANY LOGO + COMPANY ADDRESS -->
                <table style="width:100%; border-collapse:collapse; margin:0 0 12px 0; padding:0; page-break-inside:avoid;">
                    <tr>
                        <td style="width:100%; vertical-align:top; text-align:left; padding:0; border:0;">

                            <!-- Logo block -->
                            <div style="display:block; width:100%; margin:0 0 6px 0; padding:0;">
                                <img t-if="o.company_id.logo"
                                     t-att-src="image_data_uri(o.company_id.logo)"
                                     style="display:block; max-width:240px; max-height:80px; margin:0; padding:0; border:0;"/>
                            </div>

                            <!-- Company block below logo -->
                            <div style="display:block; width:100%; margin:0; padding:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.35; color:#172033; text-align:left;">
                                <div style="font-size:14px; font-weight:700; color:#172033; margin:0 0 2px 0; padding:0;">
                                    <span t-esc="o.company_id.parent_id.name or o.company_id.name or ''"/>
                                </div>

                                <div t-if="o.company_id.partner_id.street" style="margin:0; padding:0;">
                                    <span t-esc="o.company_id.partner_id.street"/>
                                </div>

                                <div t-if="o.company_id.partner_id.street2" style="margin:0; padding:0;">
                                    <span t-esc="o.company_id.partner_id.street2"/>
                                </div>

                                <div t-if="o.company_id.partner_id.city or o.company_id.partner_id.zip" style="margin:0; padding:0;">
                                    <span t-esc="o.company_id.partner_id.city or ''"/>
                                    <span t-if="o.company_id.partner_id.zip">
                                        <span> </span>
                                        <span t-esc="o.company_id.partner_id.zip"/>
                                    </span>
                                </div>

                                <div t-if="o.company_id.partner_id.state_id or o.company_id.partner_id.country_id" style="margin:0; padding:0;">
                                    <span t-esc="o.company_id.partner_id.state_id.name or ''"/>
                                    <span t-if="o.company_id.partner_id.state_id and o.company_id.partner_id.country_id"> </span>
                                    <span t-esc="o.company_id.partner_id.country_id.name or ''"/>
                                </div>
                            </div>

                        </td>
                    </tr>
                </table>
                                <!-- PURCHASE ORDER TITLE -->
                <table class="po-title-table">
                    <tr>
                        <td class="po-title-left">
                            <h1 class="po-title" t-if="o.state in ['draft', 'sent', 'to approve']">Request for Quotation</h1>
                            <h1 class="po-title" t-if="o.state in ['purchase', 'done']">Purchase Order</h1>
                            <h1 class="po-title" t-if="o.state == 'cancel'">Cancelled Purchase Order</h1>
                            <div class="po-subtitle">Professional purchase document generated from Odoo</div>
                        </td>

                        <td class="po-title-right">
                            <span class="po-badge">
                                <span t-field="o.name"/>
                            </span>
                        </td>
                    </tr>
                </table>

                <!-- SUPPLIER / BUYER -->
                <table class="po-card">
                    <tr>
                        <td style="width:50%;">
                            <div class="po-section-head">Supplier / Bill From</div>

                            <div class="po-address">
                                <div t-field="o.partner_id"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                            </div>
                        </td>

                        <td style="width:50%;">
                            <div class="po-section-head">Buyer / Bill To</div>

                            <div class="po-address">
                                <strong>
                                    <span t-esc="o.company_id.parent_id.name or o.company_id.partner_id.name or ''"/>
                                </strong>
                                <br/>

                                <span t-esc="o.company_id.partner_id.street or ''"/>
                                <span t-if="o.company_id.partner_id.street2">
                                    <span>, </span>
                                    <span t-esc="o.company_id.partner_id.street2"/>
                                </span>
                                <br t-if="o.company_id.partner_id.street or o.company_id.partner_id.street2"/>

                                <span t-esc="o.company_id.partner_id.city or ''"/>
                                <span t-if="o.company_id.partner_id.state_id">
                                    <span>, </span>
                                    <span t-esc="o.company_id.partner_id.state_id.name"/>
                                </span>
                                <span t-if="o.company_id.partner_id.zip">
                                    <span> - </span>
                                    <span t-esc="o.company_id.partner_id.zip"/>
                                </span>
                                <br t-if="o.company_id.partner_id.city or o.company_id.partner_id.state_id or o.company_id.partner_id.zip"/>

                                <span t-esc="o.company_id.partner_id.country_id.name or ''"/>
                                <br t-if="o.company_id.partner_id.country_id"/>

                                <span t-if="o.company_id.partner_id.vat">
                                    GSTIN:
                                    <span t-esc="o.company_id.partner_id.vat"/>
                                </span>
                            </div>
                        </td>
                    </tr>
                </table>

                <!-- PO META -->
                <table class="po-meta-table">
                    <tr>
                        <td style="width:25%;">
                            <span class="po-label">PO Name</span>
                            <span class="po-value" t-field="o.name"/>
                        </td>

                        <td style="width:25%;">
                            <span class="po-label">Purchase Representative</span>
                            <span class="po-value" t-field="o.user_id"/>
                        </td>

                        <td style="width:25%;">
                            <span class="po-label">Vendor Reference</span>
                            <span class="po-value" t-field="o.partner_ref"/>
                        </td>

                        <td style="width:25%;">
                            <span class="po-label">Order Date</span>
                            <span class="po-value" t-field="o.date_approve" t-options="{'widget': 'date'}"/>
                        </td>
                    </tr>
                </table>

                <!-- ORDER LINES -->
                <table class="po-lines">
                    <thead>
                        <tr>
                            <th class="po-col-sr">Sr</th>
                            <th class="po-col-desc">Description</th>
                            <th class="po-col-hsn">HSN</th>
                            <th class="po-col-tax">Taxes</th>
                            <th class="po-col-qty">Qty</th>
                            <th class="po-col-rate">Rate</th>
                            <th class="po-col-amt">Amount</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-set="qty" t-value="0"/>
                        <t t-set="amt" t-value="0"/>
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-set="current_section" t-value="False"/>
                        <t t-set="sq_no" t-value="1"/>

                        <t t-foreach="o.order_line" t-as="line">

                            <t t-set="current_subtotal"
                               t-value="current_subtotal + line.price_subtotal"
                               groups="account.group_show_line_subtotals_tax_excluded"/>

                            <t t-set="current_subtotal"
                               t-value="current_subtotal + line.price_total"
                               groups="account.group_show_line_subtotals_tax_included"/>

                            <tr t-if="not line.display_type">
                                <td class="po-col-sr">
                                    <span t-esc="sq_no"/>
                                    <t t-set="sq_no" t-value="sq_no + 1"/>
                                </td>

                                <td class="po-col-desc po-line-desc">
                                    <div class="po-product-name">
                                        <span t-field="line.product_id.name"/>
                                    </div>

                                    <div class="po-muted">
                                        <span t-field="line.name"/>
                                    </div>
                                </td>

                                <td class="po-col-hsn">
                                    <span t-esc="line.product_id.l10n_in_hsn_code or ''  "/>
                                </td>

<td class="po-col-tax">
    <span t-esc="line._fields.get('tax_ids') and line.tax_ids and ', '.join(map(lambda x: x.name or '', line.tax_ids)) or ''"/>
</td>

                                <td class="po-col-qty">
                                    <span t-field="line.product_qty"/>
                                    <t t-set="qty" t-value="qty + line.product_qty"/>
                                    <span t-field="line.product_uom_id.name" groups="uom.group_uom"/>
                                </td>

                                <td class="po-col-rate">
                                    <span t-field="line.price_unit"/>
                                </td>

                                <td class="po-col-amt">
<span t-esc="o.currency_id.symbol or ''"/>
<span> </span>
<span t-esc="'%.2f' % line.price_subtotal"/>
                                    <t t-set="amt" t-value="amt + line.price_subtotal"/>
                                </td>
                            </tr>

                            <tr t-if="line.display_type == 'line_section'" class="po-section-row">
                                <td colspan="7">
                                    <span t-field="line.name"/>
                                </td>
                            </tr>

                            <t t-if="line.display_type == 'line_section'">
                                <t t-set="current_section" t-value="line"/>
                                <t t-set="current_subtotal" t-value="0"/>
                            </t>

                            <tr t-if="line.display_type == 'line_note'" class="po-note-row">
                                <td colspan="7">
                                    <span t-field="line.name"/>
                                </td>
                            </tr>

                            <t t-if="current_section and (line_last or o.order_line[line_index+1].display_type == 'line_section')">
                                <tr class="po-subtotal-row">
                                    <td colspan="7">
                                        <strong>Subtotal: </strong>
                                        <span t-esc="current_subtotal"
                                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>

                        </t>

                        <tr class="po-total-row">
                            <td colspan="4" class="po-right">Total</td>

                            <td class="po-col-qty">
                                <span t-esc="qty"/>
                            </td>

                            <td class="po-col-rate"></td>

                            <td class="po-col-amt">
<span t-esc="o.currency_id.symbol or ''"/>
<span> </span>
<span t-esc="'%.2f' % amt"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- TAX TOTALS -->
                <table class="po-summary-wrap">
                    <tr>
                        <td class="po-summary-left"></td>

                        <td class="po-summary-right">
                            <table class="po-tax-table">
                                <t t-set="tax_totals" t-value="o.tax_totals"/>
                                <t t-set="currency" t-value="o.currency_id or o.company_id.currency_id"/>
                                <t t-call="account.document_tax_totals"/>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- AMOUNT IN WORDS -->
                <div class="po-amount-words">
                    <strong>Amount Chargeable (in words): </strong>
                    <span t-esc="o._compute_total_claimable_amt_words(o.amount_total).capitalize()"/>
                    <span> only</span>
                </div>

<div class="po-note-box" t-if="o.note">
    <div class="po-section-head">Terms and Conditions / Notes</div>
    <div class="po-note-content" t-field="o.note"/>
</div>

                <!-- SIGNATURE -->
                <table class="po-sign-table">
                    <tr>
                        <td style="width:50%;">
                            <div class="po-section-head">Prepared By</div>
                            <span t-field="o.user_id"/>
                        </td>

                        <td style="width:50%; text-align:right;">
                            <strong>
                                For
                                <span t-field="o.company_id.parent_id.name"/>
                            </strong>

                            <div class="po-sign-space"></div>

                            <div class="po-digital-note">
                                This is a digitally generated purchase order and does not require signature.
                            </div>
                        </td>
                    </tr>
                </table>

            </div>
        </div>

    </template>

    <template id="report_purchaseorder1">
        <t t-call="web.html_container">
            <meta charset="UTF-8" />
            <t t-foreach="docs" t-as="o">
                <t t-call="csspl_india.report_purchaseorder_document1" t-lang="o.partner_id.lang"/>
            </t>
